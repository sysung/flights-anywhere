# Flights Anywhere - Environment Variables Template
# Rename this file to .env and fill in your values.

# --- Core Configuration ---
ENVIRONMENT=development # Set to 'production' for strict CORS
TIMEZONE=America/Los_Angeles
LOG_LEVEL=INFO

# --- API Keys ---
# Google Gemini API Key (Required for AI Flight Assistant)
GOOGLE_CLOUD_API_KEY=xxxxx
GEMINI_MODEL=gemini-3.5-flash

# --- Google Flights Session ---
GOOGLE_FLIGHTS_SESSION_PATH=/app/api/.session/google_flights_session.json
GOOGLE_FLIGHTS_SESSION_TTL_SECONDS=3600
GOOGLE_FLIGHTS_SESSION_CAPTURE_TIMEOUT_SECONDS=45
GOOGLE_FLIGHTS_SESSION_BOOTSTRAP_ORIGIN=SFO

# --- Railway Integration ---
# Railway injects PORT automatically. Do not hardcode it in Railway variables.
# Automatically populated by Railway if using public networking
# RAILWAY_PUBLIC_DOMAIN=your-app-domain.up.railway.app

# --- Other Provider Templates (not currently used) ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
ELEVEN_LABS_API_KEY=xxxxx
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_REGION=us-west-2
